{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Build (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build",
                "--parallel"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "silent",
                "revealProblems": "onProblem"
            }
        },
        {
            "label": "CMake: Configure (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}/build",
                "-DCMAKE_BUILD_TYPE=Debug"
            ],
            "problemMatcher": []
        },
        {
            "label": "Flutter: Build Native Bridge (iOS Sim)",
            "type": "shell",
            "command": "${workspaceFolder}/apps/flutter/scripts/build_native.sh",
            "args": ["sim"],
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "silent",
                "revealProblems": "onProblem"
            }
        }
    ]
}
