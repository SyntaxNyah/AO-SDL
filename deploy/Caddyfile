{$KAGAMI_DOMAIN:canary.attorneyoffline.de} {
	# Grafana (served from /grafana/, handles its own sub-path via GF_SERVER_SERVE_FROM_SUB_PATH)
	handle /grafana* {
		reverse_proxy grafana:3000
	}

	# Prometheus (served from /prometheus/, configured via --web.external-url)
	handle /prometheus* {
		reverse_proxy prometheus:9090
	}

	# Everything else goes to kagami (game server API, /metrics, root)
	handle {
		reverse_proxy kagami:80 {
			transport http {
				keepalive 60s
				keepalive_idle_conns 64
				max_conns_per_host 256
			}
		}
	}
}
