          "id": "organize",
          "options": {
            "renameByName": {
              "display_name 1": "name",
              "protocol 1": "protocol",
              "area 1": "area",
              "character 1": "character",
              "Value #idle": "idle",
              "Value #bytes_out": "bytes_out",
              "Value #bytes_in": "bytes_in",
              "Value #pkts_out": "pkts_out",
              "Value #pkts_in": "pkts_in"
            },
            "indexByName": {
              "session_id": 0,
              "name": 1,
              "character": 2,
              "protocol": 3,
              "area": 4,
              "bytes_out": 5,
              "bytes_in": 6,
              "pkts_out": 7,
              "pkts_in": 8,
              "idle": 9
            }
          }
        }
      ],
