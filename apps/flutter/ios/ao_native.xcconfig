// Link the pre-built AO-SDL native bridge and all its dependencies.
// Automatically selects simulator or device libs based on Xcode's target SDK.

AO_LIB_DIR[sdk=iphoneos*] = $(SRCROOT)/libs/ios-device
AO_LIB_DIR[sdk=iphonesimulator*] = $(SRCROOT)/libs/ios-sim
AO_THIRDPARTY_DIR = $(AO_LIB_DIR)/third-party

// -force_load on ao_bridge only — this ensures all ao_* symbols survive
// dead-stripping (Dart FFI resolves them at runtime via dlsym).
// The remaining libs are linked normally; the bridge's references pull them in.
AO_COMMON_LDFLAGS = $(inherited) -force_load $(AO_LIB_DIR)/libao_bridge.a -lao_protocol -lao_game -lao_net -laoengine -laorender_metal -lopusfile -lwebp -lwebpdecoder -lwebpdemux -lsharpyuv -logg -lopus -lz -lc++ -framework Metal -framework MetalKit -framework QuartzCore -framework CoreText -framework Foundation -framework IOKit -framework AudioToolbox -framework CoreAudio -framework AVFoundation
OTHER_LDFLAGS[sdk=iphoneos*] = $(AO_COMMON_LDFLAGS) -lbit7z64 -lfreetype
OTHER_LDFLAGS[sdk=iphonesimulator*] = $(AO_COMMON_LDFLAGS) -lbit7z64_d -lfreetyped
LIBRARY_SEARCH_PATHS = $(inherited) $(AO_LIB_DIR) $(AO_LIB_DIR)/lib $(AO_THIRDPARTY_DIR)/freetype $(AO_THIRDPARTY_DIR)/libwebp $(AO_THIRDPARTY_DIR)/ogg $(AO_THIRDPARTY_DIR)/opus
